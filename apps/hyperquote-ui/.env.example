# ──────────────────────────────────────────────────────────────────────────────
# HyperQuote UI — Environment Variables
# Copy this file to .env.local and fill in values for your deployment.
#
# In development, missing vars fall back to localhost defaults.
# In production (NODE_ENV=production), critical vars must be set or build fails.
# ──────────────────────────────────────────────────────────────────────────────

# ── Critical (required for production) ───────────────────────────────────────

# Deployed HyperEvmRfq (spot) contract address
NEXT_PUBLIC_SPOT_RFQ_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# ── Contract Addresses (recommended) ────────────────────────────────────────

# Deployed OptionsEngine contract address (set when options are live)
# NEXT_PUBLIC_OPTIONS_ENGINE_ADDRESS=0x...

# ── Chain Configuration ─────────────────────────────────────────────────────

NEXT_PUBLIC_CHAIN_ID=999999
NEXT_PUBLIC_CHAIN_NAME=HyperEVM
NEXT_PUBLIC_RPC_URL=https://rpc.hyperevm.io
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://explorer.hyperevm.io

# ── Service URLs (default to localhost in dev) ──────────────────────────────

# WebSocket relay URL (default: ws://127.0.0.1:8080)
# NEXT_PUBLIC_RELAY_WS_URL=ws://127.0.0.1:8080

# Terminal REST API URL (default: http://127.0.0.1:4200)
# NEXT_PUBLIC_TERMINAL_API_URL=http://127.0.0.1:4200

# Documentation site URL (default: http://localhost:3001 in dev)
# In production, set to https://docs.hyperquote.xyz
NEXT_PUBLIC_DOCS_URL=http://localhost:3001

# Set to "true" to enable relay connectivity
NEXT_PUBLIC_USE_RELAY=false

# ── Optional: WalletConnect ─────────────────────────────────────────────────
# Get a project ID from https://cloud.walletconnect.com
# Leave empty to disable WalletConnect (MetaMask / injected wallets still work)

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Optional: Block Explorer API (server-side) ─────────────────────────────
# Used by /api/explorer/contract-status to verify contract deployment.

EXPLORER_API_KEY=
EXPLORER_CHAIN_ID=999
EXPLORER_API_BASE=https://api.etherscan.io/v2/api

# ── Optional: Server-side RPC (badge lookups, SOR) ───────────────────────
# Overrides NEXT_PUBLIC_RPC_URL for server-side viem client (badges, etc.).
# Leave empty to use NEXT_PUBLIC_RPC_URL as fallback.

# SOR_RPC_URL=https://rpc.hyperliquid.xyz/evm

# ── Optional: Aggregator Benchmarks (server-side) ──────────────────────────
# HyperBloom aggregator API key for benchmark pricing comparison.

HYPERBLOOM_API_KEY=

# ── App URL (for server-side redirects, leaderboard self-links) ──────────
# NEXT_PUBLIC_APP_URL=https://app.hyperquote.io

# ── Options Configuration ────────────────────────────────────────────────
# Chain ID for options contract verification (default: same as NEXT_PUBLIC_CHAIN_ID)
# NEXT_PUBLIC_OPTIONS_CHAIN_ID=999999

# Edge basis points for RFQ pricing (default: 0)
# NEXT_PUBLIC_RFQ_EDGE_BPS=0

# ── Database (server-side) ───────────────────────────────────────────────
# SQLite in dev, PostgreSQL in production
# DATABASE_URL=file:./prisma/dev.db

# ── Feature Flags ─────────────────────────────────────────────────────────
# Set to "true" to enable Options and Terminal UI sections

NEXT_PUBLIC_ENABLE_OPTIONS=false
NEXT_PUBLIC_ENABLE_TERMINAL=false

# Mock mode for testing (feed, league, points pages use mock data)
# NEXT_PUBLIC_MOCK_MODE=false

# ── Telegram Notifications ──────────────────────────────────────────────────
# Bot token and channel/group ID for RFQ feed notifications.
# Leave empty to disable Telegram broadcasts (default in dev).

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Scripts only (not used at runtime) ──────────────────────────────────────
# RPC endpoint used by token-list build scripts (scripts/*.ts)

# NEXT_PUBLIC_HYPEREVM_RPC_URL=https://rpc.hyperevm.io
