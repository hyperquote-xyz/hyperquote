{
  "name": "hyperquote-v3",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/hyperquote-ui",
    "apps/docs",
    "packages/sdk-maker",
    "packages/sdk-agent",
    "services/relay",
    "services/alert-stream",
    "services/terminal-api",
    "services/terminal-ingest",
    "services/telegram-bot"
  ],
  "scripts": {
    "dev:ui": "npm run dev --workspace=apps/hyperquote-ui",
    "build:ui": "npm run build --workspace=apps/hyperquote-ui",
    "lint:ui": "npm run lint --workspace=apps/hyperquote-ui",
    "typecheck:ui": "npm run typecheck --workspace=apps/hyperquote-ui",
    "dev:docs": "npm run dev --workspace=apps/docs",
    "build:docs": "npm run build --workspace=apps/docs",
    "dev:relay": "npm run dev --workspace=services/relay",
    "build:relay": "npm run build --workspace=services/relay",
    "typecheck:relay": "npm run typecheck --workspace=services/relay",
    "dev:alert-stream": "npm run dev --workspace=services/alert-stream",
    "build:alert-stream": "npm run build --workspace=services/alert-stream",
    "typecheck:alert-stream": "npm run typecheck --workspace=services/alert-stream",
    "dev:terminal-api": "npm run dev --workspace=services/terminal-api",
    "build:terminal-api": "npm run build --workspace=services/terminal-api",
    "typecheck:terminal-api": "npm run typecheck --workspace=services/terminal-api",
    "dev:terminal-ingest": "npm run dev --workspace=services/terminal-ingest",
    "build:terminal-ingest": "npm run build --workspace=services/terminal-ingest",
    "typecheck:terminal-ingest": "npm run typecheck --workspace=services/terminal-ingest",
    "dev:telegram-bot": "npm run dev --workspace=services/telegram-bot",
    "build:telegram-bot": "npm run build --workspace=services/telegram-bot",
    "typecheck:telegram-bot": "npm run typecheck --workspace=services/telegram-bot",
    "build:sdk": "npm run build --workspace=packages/sdk-maker",
    "build:sdk-agent": "npm run build --workspace=packages/sdk-agent",
    "typecheck:sdk": "npm run typecheck --workspace=packages/sdk-maker",
    "typecheck:sdk-agent": "npm run typecheck --workspace=packages/sdk-agent",
    "test:sdk": "npm run test --workspace=packages/sdk-maker",
    "test:sdk-agent": "npm run test --workspace=packages/sdk-agent",
    "lint:all": "npm run lint:ui",
    "typecheck:all": "npm run typecheck:sdk && npm run typecheck:sdk-agent && npm run typecheck:relay && npm run typecheck:alert-stream && npm run typecheck:terminal-api && npm run typecheck:terminal-ingest && npm run typecheck:telegram-bot && npm run typecheck:ui",
    "build:all": "npm run build:sdk && npm run build:sdk-agent && npm run build:relay && npm run build:alert-stream && npm run build:terminal-api && npm run build:terminal-ingest && npm run build:telegram-bot && npm run build:ui",
    "check:all": "npm run lint:all && npm run typecheck:all && npm run build:all",
    "dev:all": "trap 'kill 0' EXIT; npm run dev:relay & npm run dev:terminal-api & npm run dev:ui & wait",
    "clean": "rm -rf apps/hyperquote-ui/.next apps/docs/.next packages/sdk-maker/dist packages/sdk-agent/dist services/relay/dist services/alert-stream/dist services/terminal-api/dist services/terminal-ingest/dist services/telegram-bot/dist"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@mdx-js/mdx": "3.0.1"
  }
}
