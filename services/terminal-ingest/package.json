{
  "name": "@hyperquote/terminal-ingest",
  "version": "1.0.0",
  "description": "HyperQuote Options Terminal — ingestion workers for Derive, HyperEVM, and Hyperliquid data",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:init": "psql $DATABASE_URL < src/schema.sql",
    "lint": "eslint src/"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "pg": "^8.13.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
