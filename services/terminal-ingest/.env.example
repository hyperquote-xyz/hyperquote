# =============================================================================
# Terminal Ingest — Environment Variables
# =============================================================================

# --- Database (required) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hq_terminal

# --- Derive (Lyra v2) ---
DERIVE_API_URL=https://api.lyra.finance/public
DERIVE_CURRENCIES=ETH,BTC                  # Comma-separated underlyings to track
DERIVE_TICKER_INTERVAL_MS=3000             # Ticker snapshot poll interval
DERIVE_TRADE_INTERVAL_MS=3000              # Trade poll interval

# --- HyperEVM Chain Indexer ---
HYPER_EVM_WS_URL=wss://api.hyperliquid.xyz/evm/ws   # WebSocket RPC
HYPER_EVM_RPC_URL=https://api.hyperliquid.xyz/evm    # HTTP RPC (fallback)
OPTIONS_ENGINE_ADDRESS=0x...                          # OptionsEngine contract
SETTLEMENT_PUBLISHER_ADDRESS=0x...                    # SettlementPublisher contract
CHAIN_POLL_INTERVAL_MS=5000                           # HTTP polling interval (if WS unavailable)

# --- Hyperliquid Spot/Perp ---
HL_API_URL=https://api.hyperliquid.xyz/info
HL_POLL_INTERVAL_MS=3000                   # allMids poll interval
HL_CONTEXT_INTERVAL_MS=10000               # metaAndAssetCtxs (rich) poll interval

# --- IV Solver ---
RISK_FREE_RATE=0.05                           # Annualized risk-free rate for Black-Scholes IV

# --- Retention ---
HL_SPOT_RETENTION_DAYS=7                      # hl_spot rows older than this are deleted daily
DERIVE_TRADES_RETENTION_DAYS=30               # derive_trades rows older than this are deleted daily

# --- Unified Tape ---
# unified_tape is a real table — workers insert directly, no refresh needed.
