# ── Required: Bot Identity ──────────────────────────────────────────────
# Get from @BotFather — the bot must be added to your channel as admin
TELEGRAM_BOT_TOKEN=

# ── Public Channel Broadcaster ──────────────────────────────────────────
# Channel username (e.g. @hyperquote) or numeric chat ID (e.g. -1001234567890)
TELEGRAM_PUBLIC_CHANNEL_ID=
# Master switch — set to "false" to disable
TELEGRAM_PUBLIC_ENABLED=true
# Post rfq.filled events to the channel. Set to "false" to only post new RFQs.
TELEGRAM_PUBLIC_INCLUDE_FILLS=true
# Minimum USD notional to post (estimated from stablecoin side). 0 = no filter.
TELEGRAM_PUBLIC_MIN_NOTIONAL_USD=100

# ── Service URLs ────────────────────────────────────────────────────────
# Next.js app URL (provides the public SSE feed at /api/v1/feed/stream)
NEXTJS_URL=http://localhost:3000
# URL for the "Open in HyperQuote" link in channel messages
HYPERQUOTE_APP_URL=https://app.hyperquote.trade

# ── Infrastructure ──────────────────────────────────────────────────────
TELEGRAM_BOT_PORT=8095
# Alert-stream WS (for future user subscription delivery — not used by public channel)
ALERT_STREAM_URL=ws://127.0.0.1:8090

# ── Encryption Key ──────────────────────────────────────────────────────
# 64-char hex string for AES-256-GCM (used for user API key storage).
# Generate with: openssl rand -hex 32
TELEGRAM_BOT_ENCRYPTION_KEY=
